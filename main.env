# main.env

# База данных 
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# CORS 
CORS_ORIGINS=*

# Настройки сессии
SESSION_TIMEOUT_SECONDS=30

# Настройки TTS

PIPER_PATH=C:\Users\Dima\AppData\Local\Programs\Python\Python313\Scripts\piper.exe
PIPER_MODEL=queue\tts\ru_RU-irina-medium.onnx
TTS_CACHE_DIR=queue\tts\cache

TTS_LENGTH_SCALE=1.05
TTS_NOISE_SCALE=0.85
TTS_NOISE_W_SCALE=0.75